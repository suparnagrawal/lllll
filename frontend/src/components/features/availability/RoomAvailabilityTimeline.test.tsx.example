import { describe, it, expect, vi } from 'vitest';
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { RoomAvailabilityTimeline } from './RoomAvailabilityTimeline';
import type { TimelineSegment } from '@/lib/api/types';

describe('RoomAvailabilityTimeline', () => {
  const mockSegments: TimelineSegment[] = [
    {
      start: '2024-01-15T08:00:00Z',
      end: '2024-01-15T09:30:00Z',
      status: 'booked',
      booking: {
        id: 1,
        title: 'Class A',
        bookedBy: 'Prof. Smith',
        purpose: 'Lecture',
        startAt: '2024-01-15T08:00:00Z',
        endAt: '2024-01-15T09:30:00Z',
      },
    },
    {
      start: '2024-01-15T09:30:00Z',
      end: '2024-01-15T12:00:00Z',
      status: 'free',
    },
    {
      start: '2024-01-15T12:00:00Z',
      end: '2024-01-15T13:00:00Z',
      status: 'booked',
      isRestricted: true,
    },
  ];

  it('renders the timeline component', () => {
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    const legend = screen.getByText('Available');
    expect(legend).toBeInTheDocument();
  });

  it('displays all three legend items', () => {
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    expect(screen.getByText('Available')).toBeInTheDocument();
    expect(screen.getByText('Booked')).toBeInTheDocument();
    expect(screen.getByText('Restricted')).toBeInTheDocument();
  });

  it('generates correct time labels', () => {
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="12:00"
      />
    );

    expect(screen.getByText('08:00')).toBeInTheDocument();
    expect(screen.getByText('09:00')).toBeInTheDocument();
    expect(screen.getByText('10:00')).toBeInTheDocument();
    expect(screen.getByText('11:00')).toBeInTheDocument();
    expect(screen.getByText('12:00')).toBeInTheDocument();
  });

  it('calls onFreeSlotClick when free segment is clicked', async () => {
    const onFreeSlotClick = vi.fn();
    const user = userEvent.setup();

    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
        onFreeSlotClick={onFreeSlotClick}
      />
    );

    const freeSegment = screen.getByTitle(/Free: 09:30 - 12:00/);
    await user.click(freeSegment);

    expect(onFreeSlotClick).toHaveBeenCalled();
    expect(onFreeSlotClick).toHaveBeenCalledWith(
      '2024-01-15T09:30:00Z',
      '2024-01-15T12:00:00Z'
    );
  });

  it('calls onSegmentClick when booked segment is clicked', async () => {
    const onSegmentClick = vi.fn();
    const user = userEvent.setup();

    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
        onSegmentClick={onSegmentClick}
      />
    );

    const bookedSegment = screen.getByTitle(/Booked: Class A/);
    await user.click(bookedSegment);

    expect(onSegmentClick).toHaveBeenCalled();
    expect(onSegmentClick).toHaveBeenCalledWith(mockSegments[0]);
  });

  it('handles empty segments array', () => {
    render(
      <RoomAvailabilityTimeline
        segments={[]}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    expect(screen.getByText('Available')).toBeInTheDocument();
  });

  it('uses default dayStart and dayEnd if not provided', () => {
    const { container } = render(
      <RoomAvailabilityTimeline segments={mockSegments} />
    );

    // Should render time labels starting from 00:00
    expect(screen.getByText('00:00')).toBeInTheDocument();
    expect(screen.getByText('23:00')).toBeInTheDocument();

    const timelineBar = container.querySelector('.bg-gray-100');
    expect(timelineBar).toBeInTheDocument();
  });

  it('displays booking details in title attribute', () => {
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    const bookedSegment = screen.getByTitle(/Prof. Smith/);
    expect(bookedSegment).toBeInTheDocument();
  });

  it('shows restricted booking title when details are masked', () => {
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    const restrictedSegment = screen.getByTitle(
      /Booked \(Details restricted\)/
    );
    expect(restrictedSegment).toBeInTheDocument();
  });

  it('displays tooltip on hover with free segment info', async () => {
    const user = userEvent.setup();
    render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    const freeSegment = screen.getByTitle(/Free: 09:30 - 12:00/);
    await user.hover(freeSegment);

    // Tooltip should appear with free status
    expect(screen.getByText('Click to book')).toBeInTheDocument();
  });

  it('renders all segments', () => {
    const { container } = render(
      <RoomAvailabilityTimeline
        segments={mockSegments}
        dayStart="08:00"
        dayEnd="14:00"
      />
    );

    // Check for the timeline segments by counting colored divs
    const segments = container.querySelectorAll('[style*="left"]');
    expect(segments.length).toBe(mockSegments.length);
  });
});
