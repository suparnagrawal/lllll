# Runtime
NODE_ENV=development
PORT=5000

# PostgreSQL (Neon/Render)
DATABASE_URL=postgres://ura_user:ura_pass@localhost:5433/ura_system
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Auth
JWT_SECRET=replace_with_strong_random_secret
SESSION_SECRET=replace_with_strong_random_session_secret

# Frontend integration
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Optional Redis
REDIS_URL=redis://localhost:6379

# Cache TTL configuration (in seconds)
CACHE_VERY_SHORT_TTL=120
CACHE_SHORT_TTL=300
CACHE_MEDIUM_TTL=1800
CACHE_LONG_TTL=3600
CACHE_VERY_LONG_TTL=7200

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP email configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_SECURE=false
