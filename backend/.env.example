# Core server configuration
DATABASE_URL=postgres://ura_user:ura_pass@localhost:5433/ura_system
REDIS_URL=redis://localhost:6379
PORT=5000
JWT_SECRET=replace_with_strong_random_secret

# Cache TTL configuration (in seconds) - adjust based on data volatility
CACHE_VERY_SHORT_TTL=120
CACHE_SHORT_TTL=300
CACHE_MEDIUM_TTL=1800
CACHE_LONG_TTL=3600
CACHE_VERY_LONG_TTL=7200

# Frontend base URL used for OAuth redirects
FRONTEND_URL=http://localhost:5173

# Comma-separated origins allowed to call backend APIs from browsers
# Example: https://your-app.vercel.app,https://your-preview.vercel.app
CORS_ORIGINS=http://localhost:5173

# Session secret for OAuth handshake session cookie
SESSION_SECRET=replace_with_strong_random_session_secret

# Google OAuth (required only if using Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SMTP email configuration (required for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
